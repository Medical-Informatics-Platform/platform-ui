{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["custom.regex"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Never update a checksum for an existing version: a re-uploaded release asset must fail CI, not be auto-repinned",
      "matchDatasources": ["github-release-attachments"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "description": "Cooldown: only propose scanner releases at least 72h old, so yanked or compromised releases never reach a PR",
      "matchDatasources": ["github-release-attachments"],
      "minimumReleaseAge": "3 days"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump tool versions and their pinned release-asset SHA256 in CI setup scripts",
      "managerFilePatterns": ["/(^|/)setup-tools\\.sh$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\n[A-Z_]+_VERSION=\"\\$\\{[A-Z_]+_VERSION:-(?<currentValue>v[0-9][0-9.]*)\\}\"\\n[A-Z_]+_SHA256=\"\\$\\{[A-Z_]+_SHA256:-(?<currentDigest>[a-f0-9]{64})\\}\""
      ]
    },
    {
      "customType": "regex",
      "description": "Bump python-version pinned in workflow files",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\n\\s*python-version:\\s*'(?<currentValue>[0-9][0-9.]*)'"
      ]
    }
  ]
}
