{
  "/services": {
    "target": "http://localhost:8080",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
    "headers": {
      "X-Forwarded-Proto": "http",
      "X-Forwarded-Host": "localhost:4200",
      "X-Forwarded-Port": "4200"
    }
  },
  "/notebook/": {
    "target": "http://localhost:8000",
    "secure": false,
    "changeOrigin": false,
    "ws": true,
    "logLevel": "debug",
    "headers": {
      "X-Forwarded-Proto": "http",
      "X-Forwarded-Host": "localhost:4200",
      "X-Forwarded-Port": "4200"
    }
  }
}
